<example id="hooks_and_secrets">
<description>
Using a hook to inject headers using secrets.
</description>
<code language="javascript">
// hooks/auth.js
module.exports = {
  attachAPIKey: async ({ context }) => {
    // Secrets are securely available in context.secrets
    const apiKey = context.secrets.EXTERNAL_API_KEY;
    
    return {
      status: 'SUCCESS',
      data: {
        headers: {
          'x-api-key': apiKey,
          'x-client-version': '1.0.0'
        }
      }
    };
  }
};

// mesh.json configuration for this hook
/*
"plugins": [
  {
    "hooks": {
      "beforeAll": {
        "composer": "./hooks/auth.js#attachAPIKey",
        "blocking": true
      }
    }
  }
]
*/
</code>
</example>

